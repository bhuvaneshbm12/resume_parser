# Postgres connection string.
# In Docker Compose, keep the hostname as "postgres".
DATABASE_URL=postgresql://postgres:postgres@postgres:5432/resumes

# Redis broker/result backend URL.
# In Docker Compose, keep the hostname as "redis".
REDIS_URL=redis://redis:6379/0

# Current LLM provider used by workers/tasks.py.
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=gemini-2.5-flash

# Application logging level.
LOG_LEVEL=INFO

# Maximum accepted upload size in megabytes.
MAX_FILE_SIZE_MB=5

# API version returned by GET /health.
APP_VERSION=1.0.0
